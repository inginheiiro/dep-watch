# =============================================================================
# Required
# =============================================================================

# GitHub Personal Access Token
# Without: 60 requests/hour (will fail with 25+ projects)
# With: 5000 requests/hour
# Get one: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Optional
# =============================================================================

# Libraries.io API Key (for dependents count)
# Without: 60 requests/minute (enough for <50 projects)
# Get one: https://libraries.io/api (free)
LIBRARIES_IO_KEY=

# Grafana admin password
GRAFANA_PASSWORD=admin123

# Collection interval in seconds
# Default: 86400 (24 hours)
COLLECT_INTERVAL=86400

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Rate limit for /collect and /reload endpoints (seconds between calls)
RATE_LIMIT_SECONDS=30
